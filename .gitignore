# Environment
.env
.env.local

# Test content (developers download their own)
test-books/

plans/

# Dictionary data
backend/EReader.Api/Data/*.sqlite

# Local book storage — user uploads land here at runtime, never commit them.
# Both paths are listed because the default storage root has moved over time.
backend/data/
# Ignore the *contents* of data/ (not the dir itself) so the committed offline
# dictionary dataset below can be re-included — git can't un-ignore a file whose
# parent directory is excluded outright.
backend/EReader.Api/data/*
!backend/EReader.Api/data/dictionary/
backend/EReader.Api/data/dictionary/*
!backend/EReader.Api/data/dictionary/wordnet.json.gz

# Build artefacts
backend/**/bin/
backend/**/obj/
frontend/.expo/
frontend/node_modules/

# OS
.DS_Store
Thumbs.db
backend/EReader.Api/appsettings.json
backend/EReader.Api/appsettings.Development.json
