# Copy this file to backend/EReader.Api/.env and fill in your local values.
# In production, set these as real environment variables — do not deploy a .env file.
# All other settings (URLs, Wikipedia API base, logging) live in appsettings.json /
# appsettings.Development.json and are committed to source control.

DATABASE_URL=Host=localhost;Port=5432;Database=ereader;Username=<user>;Password=<password>

# JWT signing key — must be ≥ 32 bytes (UTF-8). Generate with:
#   openssl rand -base64 48
JWT__KEY=<paste-a-long-random-secret-here>

# Redis connection string for the refresh token store.
REDIS__CONNECTIONSTRING=localhost:6379

# Postgres password for the dockerised database. Used by docker/docker-compose.yml,
# NOT by the backend itself. Compose resolves it from its environment, so point
# Compose at this file when bringing the stack up:
#   docker compose --env-file backend/EReader.Api/.env -f docker/docker-compose.yml up -d
# (or export DB_PASSWORD in your shell). It MUST match the Password=... in DATABASE_URL.
DB_PASSWORD=<db password>
