# Frontend environment — copy to .env (gitignored) and adjust per target.
#
# EXPO_PUBLIC_API_URL is the base URL the app uses for all API calls. It is
# inlined at build/start time (EXPO_PUBLIC_* vars are public — never put secrets
# here). Pick the value that matches where the app runs:
#
#   Web (expo start --web), iOS simulator ...... http://localhost:5000
#   Android emulator ........................... http://10.0.2.2:5000
#   Physical device (same Wi-Fi as the host) ... http://<your-LAN-IP>:5000
#
# For EAS builds this is set per profile in eas.json instead of here.
EXPO_PUBLIC_API_URL=http://localhost:5000
