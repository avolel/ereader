{
  "name": "frontend",
  "version": "1.0.0",
  "main": "expo-router/entry",
  "dependencies": {
    "@expo/metro-runtime": "~56.0.12",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@tanstack/react-query": "^5.62.7",
    "axios": "^1.16.1",
    "expo": "~56.0.4",
    "expo-document-picker": "~56.0.4",
    "expo-router": "~56.2.6",
    "expo-secure-store": "~15.0.7",
    "expo-status-bar": "~56.0.4",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-native": "0.85.3",
    "react-native-safe-area-context": "~5.7.0",
    "react-native-screens": "4.25.2",
    "react-native-web": "^0.21.2",
    "react-native-webview": "13.16.1"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@react-native/jest-preset": "^0.85.3",
    "@testing-library/jest-native": "^5.4.3",
    "@testing-library/react-native": "^13.3.3",
    "@types/jest": "^29.5.14",
    "@types/react": "~19.2.2",
    "detox": "^20.50.4",
    "jest": "^29.7.0",
    "jest-expo": "^56.0.4",
    "typescript": "~6.0.3"
  },
  "scripts": {
    "start": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "test": "jest",
    "test:watch": "jest --watchAll",
    "test:coverage": "jest --coverage",
    "test:e2e:web": "playwright test",
    "test:e2e:web:ui": "playwright test --ui",
    "test:e2e:ios": "detox test --configuration ios.sim.debug",
    "test:e2e:android": "detox test --configuration android.emu.debug",
    "test:e2e:ios:build": "detox build --configuration ios.sim.debug",
    "test:e2e:android:build": "detox build --configuration android.emu.debug"
  },
  "private": true
}
